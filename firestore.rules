rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // ===============================================================
    // Assumed Data Model
    // ===============================================================
    //
    // Collection: users
    // Document ID: {email}
    // Fields:
    //   - email: string (required)
    //   - username: string (required)
    //   - totalScore: number (required)
    //   - dailyScores: map (required)
    //
    // Collection: leaderboard
    // Document ID: {email}
    // Fields:
    //   - username: string (required)
    //   - totalScore: number (required)
    //
    // ===============================================================

    // ===============================================================
    // Helper Functions
    // ===============================================================
    
    // NOTE: Since we are not using Firebase Auth (as requested), 
    // we cannot verify identity on the server side. 
    // These rules are trust-based.

    function isValidUser(data) {
      return data.keys().hasAll(['email', 'username', 'totalScore', 'dailyScores']) &&
             data.email is string && data.email.size() < 100 &&
             data.username is string && data.username.size() > 0 && data.username.size() < 50 &&
             data.totalScore is number &&
             data.dailyScores is map;
    }

    function isValidLeaderboardEntry(data) {
      return data.keys().hasAll(['username', 'totalScore']) &&
             data.username is string && data.username.size() < 50 &&
             data.totalScore is number;
    }

    // ===============================================================
    // Rules
    // ===============================================================

    match /users/{userId} {
      allow read: if true;
      allow create: if isValidUser(request.resource.data) && request.resource.data.totalScore == 0;
      allow update: if isValidUser(request.resource.data) && request.resource.data.email == resource.data.email;
      // Admin actions are handled by the client logic for now
      allow delete: if true; 
    }

    match /leaderboard/{userId} {
      allow read: if true;
      allow create, update: if isValidLeaderboardEntry(request.resource.data);
      allow delete: if true;
    }

    // Default deny
    match /{path=**} {
      allow read, write: if false;
    }
  }
}
